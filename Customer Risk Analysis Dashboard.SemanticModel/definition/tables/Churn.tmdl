table Churn
	lineageTag: e124c588-de88-4e30-a61a-eccf8f7370a9

	measure 'Senior Citizen' = DIVIDE(CALCULATE(COUNT(Churn[SeniorCitizen]),Churn[SeniorCitizen]=1,Churn[Churn]="Yes"), CALCULATE(COUNT(Churn[SeniorCitizen]),Churn[Churn]="Yes"),0)
		formatString: 0%;-0%;0%
		lineageTag: b9831992-5d21-4d47-ab49-cd081b44bc16

	measure '% of partner' = DIVIDE(CALCULATE(COUNT(Churn[Partner]),Churn[Partner]="Yes", Churn[Churn]="Yes"),CALCULATE(COUNT(Churn[Partner]),Churn[Churn]="Yes"),0)
		formatString: 0%;-0%;0%
		lineageTag: d77a9943-0f3c-495f-884d-1950f6ae4139

	measure '% of Dependents' = DIVIDE(CALCULATE(COUNT(Churn[Dependents]),Churn[Dependents]="Yes",Churn[Churn]="Yes"),CALCULATE(COUNT(Churn[Dependents]),Churn[Churn]="Yes"),0)
