	measure '% Yes-Multiple Lines' = DIVIDE(CALCULATE(COUNT(Churn[MultipleLines]),Churn[MultipleLines]="Yes",Churn[Churn]="Yes"),CALCULATE(COUNT(Churn[MultipleLines]),Churn[Churn]="Yes", Churn[MultipleLines] <> "No Phone Service"),0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 58049415-3b35-4f2d-a7d0-d4550cb3318b

	measure '% No-Multiple Lines' = DIVIDE(CALCULATE(COUNT(Churn[MultipleLines]),Churn[MultipleLines]="No",Churn[Churn]="Yes"),CALCULATE(COUNT(Churn[MultipleLines]),Churn[Churn]="Yes", Churn[MultipleLines] <> "No Phone Service"),0)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d5fafd2f-b788-44c7-9f4e-24425d60028c

	measure '% Churn Rate' = DIVIDE(CALCULATE(COUNT(Churn[Churn]),Churn[Churn]="Yes"),COUNT(Churn[Churn]),02)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 01ab6c87-9562-4001-b30c-72551ed5a619

