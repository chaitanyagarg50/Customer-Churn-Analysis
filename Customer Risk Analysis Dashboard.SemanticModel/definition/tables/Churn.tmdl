	measure '% Phone Service' = DIVIDE(CALCULATE(COUNT(Churn[PhoneService]),Churn[PhoneService]="Yes",Churn[Churn]="Yes"), CALCULATE(COUNT(Churn[PhoneService]), Churn[Churn]="Yes"),0)
		formatString: 0%;-0%;0%
