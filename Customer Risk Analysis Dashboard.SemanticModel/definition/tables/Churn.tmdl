	measure '% Streaming Movies' = DIVIDE(CALCULATE(COUNT(Churn[StreamingMovies]),Churn[StreamingMovies]="Yes",Churn[Churn]="Yes"),CALCULATE(COUNT(Churn[StreamingMovies]),Churn[Churn]="Yes"),0)
