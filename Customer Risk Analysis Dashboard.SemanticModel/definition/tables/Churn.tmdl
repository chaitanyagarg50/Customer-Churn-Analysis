	measure '% Online Sec' = DIVIDE(CALCULATE(COUNT(Churn[OnlineSecurity]),Churn[OnlineSecurity]="Yes", Churn[Churn]="Yes"),CALCULATE(COUNT(Churn[OnlineSecurity]),Churn[Churn]="Yes"),0)
